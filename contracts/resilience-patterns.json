{
  "schemaVersion": 1,
  "lastUpdated": "2026-04-02T21:00:00Z",
  "description": "Maps known failure patterns to automatic workarounds. Used by autonomy-improver and ci-self-heal to auto-recover without human intervention.",
  "patterns": [
    {
      "id": "api-credit-low",
      "trigger": "Credit balance is too low",
      "category": "billing",
      "severity": "high",
      "affectedWorkflows": ["claude-assistant.yml"],
      "workaround": {
        "type": "fallback-model",
        "strategy": "Switch to cheaper model (Haiku) + direct API fallback via curl",
        "implementation": "claude_args: --model claude-haiku-4-5-20251001 --max-turns 3, then curl fallback",
        "costReduction": "18x cheaper ($0.80/1M vs $15/1M)"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "api-rate-limit",
      "trigger": "rate_limit|429|Too Many Requests",
      "category": "api",
      "severity": "medium",
      "affectedWorkflows": ["claude-assistant.yml", "ci-failure-analysis.yml"],
      "workaround": {
        "type": "retry-with-backoff",
        "strategy": "Exponential backoff: 2s, 4s, 8s, 16s. Max 4 retries.",
        "implementation": "for i in 1 2 3 4; do curl ... && break; sleep $((2**i)); done"
      },
      "autoFix": true,
      "status": "ready"
    },
    {
      "id": "token-expired",
      "trigger": "401|403|Bad credentials|token expired",
      "category": "auth",
      "severity": "critical",
      "affectedWorkflows": ["apply-source-change.yml", "fix-corporate-ci.yml", "promote-cap.yml"],
      "workaround": {
        "type": "escalate",
        "strategy": "Cannot auto-fix expired tokens. Create @claude issue with instructions to check Settings > Secrets.",
        "implementation": "gh api repos/.../issues POST with needs-claude label"
      },
      "autoFix": false,
      "status": "implemented"
    },
    {
      "id": "ci-lint-failure",
      "trigger": "eslint|problems \\(.*errors\\)|Lint error",
      "category": "ci",
      "severity": "medium",
      "affectedWorkflows": ["apply-source-change.yml"],
      "workaround": {
        "type": "auto-fix-and-retry",
        "strategy": "Run eslint --fix, commit, re-trigger CI",
        "implementation": "fix-corporate-ci.yml auto-dispatched by ci-monitor-loop"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "ci-test-failure",
      "trigger": "Test Suites:.*failed|FAIL |jest.*failed",
      "category": "ci",
      "severity": "high",
      "affectedWorkflows": ["apply-source-change.yml"],
      "workaround": {
        "type": "diagnose-and-escalate",
        "strategy": "Download logs, analyze error pattern, match against errorRecovery, create fix patch or escalate",
        "implementation": "ci-diagnose.yml + ci-failure-analysis.yml pipeline"
      },
      "autoFix": false,
      "status": "implemented"
    },
    {
      "id": "ci-typescript-error",
      "trigger": "error TS[0-9]|tsc.*error|Cannot find module",
      "category": "ci",
      "severity": "high",
      "affectedWorkflows": ["apply-source-change.yml"],
      "workaround": {
        "type": "diagnose-and-fix",
        "strategy": "Parse TS error codes, add missing imports/types, fix type mismatches",
        "implementation": "ci-self-heal.yml pattern matching"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "network-timeout",
      "trigger": "ETIMEDOUT|ECONNREFUSED|ECONNRESET|socket hang up",
      "category": "network",
      "severity": "medium",
      "affectedWorkflows": ["*"],
      "workaround": {
        "type": "retry-with-backoff",
        "strategy": "Retry up to 4x with exponential backoff. If persistent, check DNS/proxy.",
        "implementation": "Built into git push/fetch retry logic"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "disk-space",
      "trigger": "ENOSPC|No space left|disk quota",
      "category": "infrastructure",
      "severity": "high",
      "affectedWorkflows": ["apply-source-change.yml", "compliance-gate.yml"],
      "workaround": {
        "type": "cleanup-and-retry",
        "strategy": "Clean npm cache, remove node_modules, reduce artifact retention",
        "implementation": "Add cleanup step before npm ci"
      },
      "autoFix": true,
      "status": "ready"
    },
    {
      "id": "duplicate-tag",
      "trigger": "tag already exists|duplicate tag|409.*tag",
      "category": "deploy",
      "severity": "high",
      "affectedWorkflows": ["apply-source-change.yml"],
      "workaround": {
        "type": "version-bump",
        "strategy": "Increment patch version and retry. Follow X.Y.9 → X.(Y+1).0 rule.",
        "implementation": "Read current tag from CAP, bump version, update 4 version files"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "merge-conflict",
      "trigger": "CONFLICT|merge conflict|cannot merge",
      "category": "git",
      "severity": "medium",
      "affectedWorkflows": ["auto-merge-sweeper.yml", "autonomous-merge-direct.yml"],
      "workaround": {
        "type": "rebase-and-retry",
        "strategy": "Fetch latest main, rebase branch, force-push, retry merge",
        "implementation": "git fetch + rebase + push in auto-merge workflows"
      },
      "autoFix": true,
      "status": "ready"
    },
    {
      "id": "workflow-disabled",
      "trigger": "is not active|workflow is disabled",
      "category": "infrastructure",
      "severity": "high",
      "affectedWorkflows": ["*"],
      "workaround": {
        "type": "re-enable",
        "strategy": "workflow-auto-repair.yml re-enables disabled workflows automatically",
        "implementation": "gh api .../actions/workflows/{id}/enable"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "stuck-run",
      "trigger": "stuck|running > 60min|queued > 30min",
      "category": "infrastructure",
      "severity": "high",
      "affectedWorkflows": ["*"],
      "workaround": {
        "type": "cancel-and-retry",
        "strategy": "Cancel stuck run, wait 30s, re-trigger",
        "implementation": "workflow-auto-repair.yml detects and cancels stuck runs"
      },
      "autoFix": true,
      "status": "implemented"
    },
    {
      "id": "action-not-found",
      "trigger": "Unable to resolve action|action does not exist",
      "category": "dependency",
      "severity": "critical",
      "affectedWorkflows": ["*"],
      "workaround": {
        "type": "pin-or-replace",
        "strategy": "Pin action to specific SHA or replace with alternative. Check GitHub Marketplace for alternatives.",
        "implementation": "Manual review needed — escalate to @claude"
      },
      "autoFix": false,
      "status": "ready"
    }
  ],
  "fallbackChain": {
    "description": "When a primary approach fails, try fallbacks in order",
    "chains": {
      "api-call": [
        {"step": 1, "method": "claude-code-action with Haiku", "cost": "low"},
        {"step": 2, "method": "Direct curl to Anthropic API with Haiku", "cost": "minimal"},
        {"step": 3, "method": "Post error comment with context", "cost": "free"}
      ],
      "ci-failure": [
        {"step": 1, "method": "ci-self-heal (auto-fix lint/types)", "cost": "free"},
        {"step": 2, "method": "fix-corporate-ci (eslint --fix)", "cost": "free"},
        {"step": 3, "method": "ci-diagnose + ci-failure-analysis", "cost": "free"},
        {"step": 4, "method": "Escalate to @claude with full context", "cost": "free"}
      ],
      "deploy-failure": [
        {"step": 1, "method": "Retry with same config", "cost": "free"},
        {"step": 2, "method": "Version bump + retry", "cost": "free"},
        {"step": 3, "method": "ci-monitor-loop re-check", "cost": "free"},
        {"step": 4, "method": "Escalate to @claude", "cost": "free"}
      ],
      "network-failure": [
        {"step": 1, "method": "Retry with 2s backoff", "cost": "free"},
        {"step": 2, "method": "Retry with 4s backoff", "cost": "free"},
        {"step": 3, "method": "Retry with 8s backoff", "cost": "free"},
        {"step": 4, "method": "Retry with 16s backoff", "cost": "free"},
        {"step": 5, "method": "Escalate — persistent network issue", "cost": "free"}
      ]
    }
  },
  "autoDiscovery": {
    "description": "When an unknown failure is encountered, the system should automatically research alternatives",
    "steps": [
      "1. Match error message against known patterns in this file",
      "2. If no match: search contracts/claude-session-memory.json errorRecovery",
      "3. If no match: create @claude issue with full error context",
      "4. @claude analyzes, implements fix, and adds new pattern to this file",
      "5. Pattern is now auto-fixable for future occurrences"
    ],
    "learningLoop": "autonomy-improver.yml reads this file + tracker → matches failures → applies workarounds → updates patterns"
  }
}
