{
  "description": "GUIA COMPLETO para o agente saber EXATAMENTE o que fazer quando o usuario fornecer qualquer credencial, endpoint, repo, token ou acesso. Cada item mapeia: o que o usuario vai enviar → onde guardar → o que ativar → como testar.",
  "instructions": "Quando o usuario enviar QUALQUER informacao listada abaixo, o agente DEVE: 1) Identificar qual item e, 2) Seguir os passos de ativacao, 3) Testar, 4) Atualizar readiness.json, 5) Confirmar ao usuario.",
  "items": {
    "aws_credentials": {
      "whatUserSends": "AWS Access Key ID + Secret Access Key (ou Role ARN para OIDC)",
      "alsoNeeded": [
        "AWS_DEFAULT_REGION (ex: us-east-1, sa-east-1)",
        "Account ID (opcional mas util)"
      ],
      "whereToStore": {
        "github_secrets": [
          "AWS_ACCESS_KEY_ID",
          "AWS_SECRET_ACCESS_KEY",
          "AWS_ROLE_ARN (se OIDC)"
        ],
        "github_variables": [
          "AWS_DEFAULT_REGION"
        ],
        "config_file": "ops/config/cloud/aws/aws-config.json → mudar status de pending para active"
      },
      "whatActivates": [
        "ops-cloud-diagnose.yml (provider=aws funciona)",
        "ops-tf-plan.yml (com backend S3)",
        "ops-k8s-health.yml (provider=aws para EKS)",
        "ops/scripts/cloud/cloud-check.sh aws",
        "Terraform com provider AWS"
      ],
      "howToTest": "Executar workflow ops-cloud-diagnose.yml com provider=aws, action=auth",
      "readinessUpdate": "aws: pending → ready"
    },
